"@
    $html | Out-File -FilePath $OutputPath -Encoding UTF8
}

# ================================================================
# HTML GENERATION — SUMMARY REPORT
# ================================================================

function New-SummaryReport {
    param ($AllAuditData, [string]$OutputPath)

    $reportDate   = Get-Date -Format "MMMM dd, yyyy HH:mm"
    $totalApps    = $AllAuditData.Count
    $totalPerms   = ($AllAuditData | ForEach-Object { $_.AuditResults.Count } | Measure-Object -Sum).Sum
    $totalNever   = ($AllAuditData | ForEach-Object { ($_.AuditResults | Where-Object { $_.Status -eq "Never Used" }).Count } | Measure-Object -Sum).Sum
    $totalCalls   = ($AllAuditData | ForEach-Object { ($_.AuditResults | Measure-Object -Property TotalCalls -Sum).Sum } | Measure-Object -Sum).Sum
    $riskApps     = ($AllAuditData | Where-Object { ($_.AuditResults | Where-Object { $_.Status -eq "Never Used" }).Count -gt 0 }).Count

    # Build app summary rows
    $appRows = ""
    foreach ($data in $AllAuditData | Sort-Object { ($_.AuditResults | Where-Object { $_.Status -eq "Never Used" }).Count } -Descending) {
        $appActiveCount   = ($data.AuditResults | Where-Object { $_.Status -eq "Active" }).Count
        $appNeverCount    = ($data.AuditResults | Where-Object { $_.Status -eq "Never Used" }).Count
        $appTotalCalls    = ($data.AuditResults | Measure-Object -Property TotalCalls -Sum).Sum
        $appTotalPerms    = $data.AuditResults.Count
        $appLastActivity  = ($data.AuditResults | Where-Object { $_.LastUsed } | Sort-Object LastUsed -Descending | Select-Object -First 1).LastUsed
        $safeAppName      = $data.AppName -replace '[^a-zA-Z0-9]', '_'
        $reportFileName   = "AppAudit_${safeAppName}.html"
        $riskBadge        = if ($appNeverCount -gt 0) { '<span class="badge badge-risk">⚠️ Has Unused Perms</span>' } else { '<span class="badge badge-ok">✅ Clean</span>' }
        $lastActivityDisplay = if ($appLastActivity) { ([datetime]$appLastActivity).ToString("yyyy-MM-dd") } else { '<span class="never">No activity</span>' }
        $credType         = if ($data.AppMeta) { $data.AppMeta.CredentialType } else { "Unknown" }
        $createdDate      = if ($data.AppMeta -and $data.AppMeta.CreatedDate) { $data.AppMeta.CreatedDate.ToString("yyyy-MM-dd") } else { "Unknown" }

        $appRows += @"
        <tr>
            <td><a href="$reportFileName"><strong>$($data.AppName)</strong></a><br><span class="appid-small">$($data.AppId)</span></td>
            <td>$createdDate</td>
            <td>$credType</td>
            <td class="num">$appTotalPerms</td>
            <td class="num" style="color:#27AE60;font-weight:600;">$appActiveCount</td>
            <td class="num" style="color:$(if($appNeverCount -gt 0){'#C0392B'}else{'inherit'});font-weight:$(if($appNeverCount -gt 0){'700'}else{'400'});">$appNeverCount</td>
            <td class="num">$appTotalCalls</td>
            <td>$lastActivityDisplay</td>
            <td>$riskBadge</td>
        </tr>
"@
    }

    # Build never-used permissions roll-up
    $neverUsedRows = ""
    $allNeverUsed  = $AllAuditData | ForEach-Object {
        $appName = $_.AppName
        $appId   = $_.AppId
        $_.AuditResults | Where-Object { $_.Status -eq "Never Used" } | ForEach-Object {
            [PSCustomObject]@{ AppName = $appName; AppId = $appId; Permission = $_.Permission; Type = $_.Type; Resource = $_.Resource }
        }
    }

    if ($allNeverUsed) {
        foreach ($n in $allNeverUsed | Sort-Object AppName, Permission) {
            $safeAppName    = $n.AppName -replace '[^a-zA-Z0-9]', '_'
            $reportFileName = "AppAudit_${safeAppName}.html"
            $typeBadge      = if ($n.Type -eq "Application") { '<span class="badge badge-app">Application</span>' } else { '<span class="badge badge-del">Delegated</span>' }
            $neverUsedRows += @"
            <tr class="row-unused">
                <td><a href="$reportFileName">$($n.AppName)</a></td>
                <td><strong>$($n.Permission)</strong></td>
                <td>$typeBadge</td>
                <td>$($n.Resource)</td>
            </tr>
"@
        }
    } else {
        $neverUsedRows = '<tr><td colspan="4" style="text-align:center;color:#27AE60;">✅ No unused permissions found across all audited applications.</td></tr>'
    }

    $html = @"
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>App Permission Audit — Summary Report</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', Arial, sans-serif; background: #f0f2f5; color: #1a1a2e; }
  .header { background: linear-gradient(135deg, #1F4E79 0%, #2E75B6 100%); color: white; padding: 32px 40px; }
  .header h1 { font-size: 26px; font-weight: 700; margin-bottom: 6px; }
  .header .sub { font-size: 14px; opacity: 0.85; }
  .container { max-width: 1200px; margin: 0 auto; padding: 30px 20px; }
  .summary-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; margin-bottom: 30px; }
  .summary-card { background: white; border-radius: 10px; padding: 20px 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.07); border-top: 4px solid #2E75B6; }
  .summary-card.red { border-top-color: #C0392B; }
  .summary-card.green { border-top-color: #27AE60; }
  .summary-card.orange { border-top-color: #E67E22; }
  .summary-card.purple { border-top-color: #8E44AD; }
  .summary-card .label { font-size: 12px; color: #888; text-transform: uppercase; letter-spacing: 0.5px; }
  .summary-card .value { font-size: 32px; font-weight: 700; color: #1F4E79; margin-top: 4px; }
  .summary-card.red .value { color: #C0392B; }
  .summary-card.green .value { color: #27AE60; }
  .summary-card.orange .value { color: #E67E22; }
  .summary-card.purple .value { color: #8E44AD; }
  .section { background: white; border-radius: 10px; padding: 24px; margin-bottom: 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.07); }
  .section h2 { font-size: 16px; font-weight: 700; color: #1F4E79; margin-bottom: 16px; padding-bottom: 10px; border-bottom: 2px solid #D5E8F0; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th { background: #1F4E79; color: white; padding: 10px 14px; text-align: left; font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: 0.4px; }
  td { padding: 10px 14px; border-bottom: 1px solid #f0f0f0; vertical-align: middle; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: #f8fbff; }
  tr.row-unused td { background: #fff8f8; }
  td.num { text-align: right; font-variant-numeric: tabular-nums; }
  .appid-small { font-size: 11px; color: #aaa; font-family: monospace; }
  .badge { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; }
  .badge-risk { background: #FDEDEC; color: #C0392B; }
  .badge-ok { background: #E8F8F0; color: #1E8449; }
  .badge-app { background: #EBF5FB; color: #1A5276; }
  .badge-del { background: #F4ECF7; color: #6C3483; }
  .never { color: #ccc; }
  a { color: #2E75B6; text-decoration: none; }
  a:hover { text-decoration: underline; }
  .footer { text-align: center; padding: 20px; font-size: 12px; color: #aaa; }
</style>
</head>
<body>
<div class="header">
  <h1>App Permission Audit — Summary Report</h1>
  <div class="sub">Tenant-wide least privilege analysis &nbsp;|&nbsp; Lookback: $LookbackDays days &nbsp;|&nbsp; Generated: $reportDate</div>
</div>
<div class="container">
  <div class="summary-grid">
    <div class="summary-card"><div class="label">Apps Audited</div><div class="value">$totalApps</div></div>
    <div class="summary-card purple"><div class="label">Apps With Unused Perms</div><div class="value">$riskApps</div></div>
    <div class="summary-card orange"><div class="label">Total Permissions</div><div class="value">$totalPerms</div></div>
    <div class="summary-card red"><div class="label">Never-Used Permissions</div><div class="value">$totalNever</div></div>
    <div class="summary-card green"><div class="label">Total API Calls ($LookbackDays d)</div><div class="value">$totalCalls</div></div>
  </div>

  <div class="section">
    <h2>All Audited Applications</h2>
    <table>
      <thead>
        <tr>
          <th>Application</th>
          <th>Created</th>
          <th>Credential Type</th>
          <th style="text-align:right">Permissions</th>
          <th style="text-align:right">Active</th>
          <th style="text-align:right">Never Used</th>
          <th style="text-align:right">Total Calls</th>
          <th>Last Activity</th>
          <th>Risk</th>
        </tr>
      </thead>
      <tbody>$appRows</tbody>
    </table>
  </div>

  <div class="section">
    <h2>Never-Used Permissions Across All Apps ($totalNever total)</h2>
    <table>
      <thead><tr><th>Application</th><th>Permission</th><th>Type</th><th>Resource</th></tr></thead>
      <tbody>$neverUsedRows</tbody>
    </table>
  </div>
</div>
<div class="footer">Entra ID App Permission Audit — Summary &nbsp;|&nbsp; Generated $reportDate &nbsp;|&nbsp; Lookback: $LookbackDays days</div>
</body>
</html>
"@
    $html | Out-File -FilePath $OutputPath -Encoding UTF8
}

# ================================================================
# MAIN EXECUTION
# ================================================================

Write-Host "`n================================================" -ForegroundColor Cyan
Write-Host "  Entra ID App Permission Audit" -ForegroundColor Cyan
Write-Host "  Lookback : $LookbackDays days" -ForegroundColor Cyan
Write-Host "  Output   : $OutputFolder" -ForegroundColor Cyan
Write-Host "================================================`n" -ForegroundColor Cyan

# Validate at least one input mode is specified
if (-not $TargetAppId -and -not $AppIdList -and -not $InputFile -and -not $DiscoverAll) {
    Write-Error "Specify an input mode: -TargetAppId, -AppIdList, -InputFile, or -DiscoverAll"
    exit 1
}

# Acquire tokens
Write-Host "[1] Acquiring access tokens..." -ForegroundColor Yellow
$graphToken = Get-AccessToken -Scope "https://graph.microsoft.com/.default"
$laToken    = Get-AccessToken -Scope "https://api.loganalytics.io/.default"
Write-Host "    Tokens acquired." -ForegroundColor Green

# Build the list of App IDs to audit
$appIdsToAudit = @()

if ($TargetAppId) {
    $appIdsToAudit += $TargetAppId
}

if ($AppIdList) {
    $appIdsToAudit += $AppIdList
}

if ($InputFile) {
    Write-Host "[2] Loading App IDs from file: $InputFile" -ForegroundColor Yellow
    if (-not (Test-Path $InputFile)) {
        Write-Error "Input file not found: $InputFile"
        exit 1
    }
    $ext = [System.IO.Path]::GetExtension($InputFile).ToLower()
    if ($ext -eq ".csv") {
        $appIdsToAudit += (Import-Csv $InputFile).AppId | Where-Object { $_ }
    } else {
        $appIdsToAudit += Get-Content $InputFile | Where-Object { $_.Trim() -ne "" }
    }
    Write-Host "    Loaded $($appIdsToAudit.Count) App ID(s) from file." -ForegroundColor Green
}

if ($DiscoverAll) {
    Write-Host "[2] Auto-discovering admin-managed app registrations..." -ForegroundColor Yellow
    $discoveredApps = Get-AllAdminManagedApps -Token $graphToken
    $appIdsToAudit  += $discoveredApps | ForEach-Object { $_.appId }
    Write-Host "    Discovered $($discoveredApps.Count) app(s) to audit." -ForegroundColor Green
}

# Deduplicate
$appIdsToAudit = $appIdsToAudit | Select-Object -Unique
Write-Host "`n[3] Auditing $($appIdsToAudit.Count) application(s)..." -ForegroundColor Yellow

# Ensure output folder exists
if (-not (Test-Path $OutputFolder)) {
    New-Item -ItemType Directory -Path $OutputFolder | Out-Null
}

# Run audit for each app
$allAuditData = @()
$counter      = 0

foreach ($appId in $appIdsToAudit) {
    $counter++
    Write-Host "  [$counter/$($appIdsToAudit.Count)]" -NoNewline -ForegroundColor Gray
    $auditData = Invoke-SingleAppAudit -AppId $appId -GraphToken $graphToken -LAToken $laToken

    if ($auditData) {
        $allAuditData += $auditData

        # Write individual report
        if (-not $SkipIndividualReports) {
            $safeAppName    = $auditData.AppName -replace '[^a-zA-Z0-9]', '_'
            $individualPath = Join-Path $OutputFolder "AppAudit_${safeAppName}.html"
            New-IndividualReport -AuditData $auditData -OutputPath $individualPath
            Write-Host "    Individual report: $individualPath" -ForegroundColor DarkGray
        }
    }
}

# Write summary report
Write-Host "`n[4] Generating summary report..." -ForegroundColor Yellow
$summaryPath = Join-Path $OutputFolder "AuditSummary.html"
New-SummaryReport -AllAuditData $allAuditData -OutputPath $summaryPath
Write-Host "    Summary report: $summaryPath" -ForegroundColor Green

# Console summary
Write-Host "`n================================================" -ForegroundColor Green
Write-Host "  Audit complete!" -ForegroundColor Green
Write-Host "================================================`n" -ForegroundColor Green

$totalNeverUsed = ($allAuditData | ForEach-Object { ($_.AuditResults | Where-Object { $_.Status -eq "Never Used" }).Count } | Measure-Object -Sum).Sum

Write-Host "SUMMARY" -ForegroundColor Cyan
Write-Host "-------" -ForegroundColor Cyan
Write-Host "Apps Audited        : $($allAuditData.Count)"
Write-Host "Total Permissions   : $(($allAuditData | ForEach-Object { $_.AuditResults.Count } | Measure-Object -Sum).Sum)"
Write-Host "Never-Used Perms    : $totalNeverUsed" -ForegroundColor $(if ($totalNeverUsed -gt 0) { "Red" } else { "Green" })
Write-Host "Reports saved to    : $OutputFolder"
Write-Host ""

# Open summary report
Write-Host "Opening summary report in browser..." -ForegroundColor Yellow
if ($IsMacOS) {
    & open $summaryPath
} elseif ($IsLinux) {
    & xdg-open $summaryPath
} else {
    Start-Process $summaryPath
}
