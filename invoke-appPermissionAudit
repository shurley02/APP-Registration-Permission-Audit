# ================================================================
# HELPER FUNCTIONS
# ================================================================

function Get-AccessToken {
    param ([string]$Scope)
    $body = @{
        client_id     = $ClientId
        client_secret = $ClientSecret
        scope         = $Scope
        grant_type    = "client_credentials"
    }
    $response = Invoke-RestMethod `
        -Method Post `
        -Uri "https://login.microsoftonline.com/$TenantId/oauth2/v2.0/token" `
        -ContentType "application/x-www-form-urlencoded" `
        -Body $body
    return $response.access_token
}

function Get-AllAdminManagedApps {
    param ([string]$Token)

    Write-Host "  Discovering admin-managed app registrations..." -ForegroundColor Yellow
    $headers = @{ Authorization = "Bearer $Token" }
    $apps    = @()
    $uri     = "https://graph.microsoft.com/v1.0/applications?`$select=id,appId,displayName,createdDateTime,passwordCredentials,keyCredentials,requiredResourceAccess&`$top=999"

    do {
        $response = Invoke-RestMethod -Method Get -Uri $uri -Headers $headers
        $apps    += $response.value
        $uri      = $response.'@odata.nextLink'
    } while ($uri)

    # Filter out Microsoft first-party apps and apps with no permissions configured
    $filtered = $apps | Where-Object {
        $_.appId -notin $MicrosoftAppIds -and
        $_.requiredResourceAccess -and
        $_.requiredResourceAccess.Count -gt 0
    }

    Write-Host "  Found $($filtered.Count) admin-managed app(s) (excluded $($apps.Count - $filtered.Count) Microsoft defaults)." -ForegroundColor Green
    return $filtered
}

function Get-GrantedPermissions {
    param ([string]$AppId, [string]$Token)

    $headers     = @{ Authorization = "Bearer $Token" }
    Add-Type -AssemblyName System.Web
    $filterQuery = "appId eq '$AppId'"
    $encoded     = [System.Web.HttpUtility]::UrlEncode($filterQuery)
    $uri         = "https://graph.microsoft.com/v1.0/applications?`$filter=$encoded&`$select=id,displayName,appId,requiredResourceAccess,createdDateTime,passwordCredentials,keyCredentials"
    $response    = Invoke-RestMethod -Method Get -Uri $uri -Headers $headers

    if (-not $response.value -or $response.value.Count -eq 0) {
        Write-Warning "No application found with appId: $AppId"
        return $null, $null, $null
    }

    $app         = $response.value[0]
    $permissions = @()

    foreach ($resource in $app.requiredResourceAccess) {
        $spUri      = "https://graph.microsoft.com/v1.0/servicePrincipals?`$filter=appId eq '$($resource.resourceAppId)'&`$select=appId,displayName,oauth2PermissionScopes,appRoles"
        $spResponse = Invoke-RestMethod -Method Get -Uri $spUri -Headers $headers
        $sp         = $spResponse.value[0]

        foreach ($access in $resource.resourceAccess) {
            $permName = "Unknown ($($access.id))"
            $permType = if ($access.type -eq "Role") { "Application" } else { "Delegated" }

            if ($access.type -eq "Role") {
                $match = $sp.appRoles | Where-Object { $_.id -eq $access.id }
                if ($match) { $permName = $match.value }
            } else {
                $match = $sp.oauth2PermissionScopes | Where-Object { $_.id -eq $access.id }
                if ($match) { $permName = $match.value }
            }

            $permissions += [PSCustomObject]@{
                Permission   = $permName
                Type         = $permType
                ResourceName = $sp.displayName
            }
        }
    }

    # Credential info for summary
    $hasSecret  = $app.passwordCredentials -and $app.passwordCredentials.Count -gt 0
    $hasCert    = $app.keyCredentials -and $app.keyCredentials.Count -gt 0
    $credType   = if ($hasSecret -and $hasCert) { "Secret + Certificate" }
                  elseif ($hasSecret) { "Client Secret" }
                  elseif ($hasCert)   { "Certificate" }
                  else                { "None" }

    $appMeta = [PSCustomObject]@{
        DisplayName   = $app.displayName
        AppId         = $app.appId
        CreatedDate   = if ($app.createdDateTime) { [datetime]$app.createdDateTime } else { $null }
        CredentialType = $credType
    }

    return $app.displayName, $permissions, $appMeta
}

function Get-LogAnalyticsUsage {
    param ([string]$AppId, [string]$Token)

    $query = @"
MicrosoftGraphActivityLogs
| where TimeGenerated > ago($($LookbackDays)d)
| where AppId == '$AppId'
| extend NormalizedUri = replace_regex(tostring(split(RequestUri, "?")[0]),
    @'[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}', '{id}')
| extend PermissionType = case(
    isempty(UserId), "Application",
    UserId == "00000000-0000-0000-0000-000000000000", "Application",
    "Delegated")
| summarize
    CallCount = count(),
    LastUsed  = max(TimeGenerated),
    FailCount = countif(ResponseStatusCode >= 400)
    by NormalizedUri, RequestMethod, PermissionType
| order by CallCount desc
"@

    $body    = @{ query = $query } | ConvertTo-Json
    $headers = @{ Authorization = "Bearer $Token"; "Content-Type" = "application/json" }
    $uri     = "https://api.loganalytics.io/v1/workspaces/$WorkspaceId/query"

    try {
        $response = Invoke-RestMethod -Method Post -Uri $uri -Headers $headers -Body $body
        $results  = @()
        if ($response.tables -and $response.tables[0].rows) {
            $cols = $response.tables[0].columns | ForEach-Object { $_.name }
            foreach ($row in $response.tables[0].rows) {
                $obj = [ordered]@{}
                for ($i = 0; $i -lt $cols.Count; $i++) { $obj[$cols[$i]] = $row[$i] }
                $results += [PSCustomObject]$obj
            }
        }
        return $results
    } catch {
        Write-Warning "Log Analytics query failed for AppId $AppId : $_"
        return @()
    }
}

function Map-UriToPermission {
    param ([string]$Uri, [string]$Method)
    foreach ($entry in $PermissionUriMap) {
        if ($Uri -like "*$($entry.Uri)*" -and $Method -eq $entry.Method) {
            return $entry.Permission
        }
    }
    return $null
}

function Invoke-SingleAppAudit {
    param ([string]$AppId, [string]$GraphToken, [string]$LAToken)

    Write-Host "  Auditing: $AppId" -ForegroundColor Yellow
    $appName, $grantedPermissions, $appMeta = Get-GrantedPermissions -AppId $AppId -Token $GraphToken

    if (-not $grantedPermissions) {
        Write-Warning "  Skipping $AppId — could not retrieve permissions."
        return $null
    }

    $usageData     = Get-LogAnalyticsUsage -AppId $AppId -Token $LAToken
    $auditResults  = @()

    foreach ($perm in $grantedPermissions) {
        $matchingUsage = $usageData | Where-Object {
            $mappedPerm = Map-UriToPermission -Uri $_.NormalizedUri -Method $_.RequestMethod
            $mappedPerm -eq $perm.Permission
        }
        $totalCalls = ($matchingUsage | Measure-Object -Property CallCount -Sum).Sum
        $totalFails = ($matchingUsage | Measure-Object -Property FailCount -Sum).Sum
        $lastUsed   = ($matchingUsage | Sort-Object LastUsed -Descending | Select-Object -First 1).LastUsed

        $auditResults += [PSCustomObject]@{
            AppName      = $appName
            AppId        = $AppId
            Permission   = $perm.Permission
            Type         = $perm.Type
            Resource     = $perm.ResourceName
            TotalCalls   = if ($totalCalls) { $totalCalls } else { 0 }
            FailedCalls  = if ($totalFails) { $totalFails } else { 0 }
            LastUsed     = if ($lastUsed) { [datetime]$lastUsed } else { $null }
            Status       = if ($totalCalls -gt 0) { "Active" } else { "Never Used" }
        }
    }

    $unmappedUris = $usageData | Where-Object {
        -not (Map-UriToPermission -Uri $_.NormalizedUri -Method $_.RequestMethod)
    }

    return [PSCustomObject]@{
        AppName       = $appName
        AppId         = $AppId
        AppMeta       = $appMeta
        AuditResults  = $auditResults
        UnmappedUris  = $unmappedUris
        UsageData     = $usageData
    }
}

