function New-IndividualReport {
    param ($AuditData, [string]$OutputPath)

    $appName        = $AuditData.AppName
    $auditResults   = $AuditData.AuditResults
    $unmappedUris   = $AuditData.UnmappedUris
    $reportDate     = Get-Date -Format "MMMM dd, yyyy HH:mm"
    $activeCount    = ($auditResults | Where-Object { $_.Status -eq "Active" }).Count
    $neverUsedCount = ($auditResults | Where-Object { $_.Status -eq "Never Used" }).Count
    $totalCalls     = ($auditResults | Measure-Object -Property TotalCalls -Sum).Sum

    $permissionRows = ""
    foreach ($r in $auditResults | Sort-Object Status, Permission) {
        $statusBadge     = if ($r.Status -eq "Active") { '<span class="badge badge-active">Active</span>' } else { '<span class="badge badge-unused">Never Used</span>' }
        $typeBadge       = if ($r.Type -eq "Application") { '<span class="badge badge-app">Application</span>' } else { '<span class="badge badge-del">Delegated</span>' }
        $lastUsedDisplay = if ($r.LastUsed) { $r.LastUsed.ToString("yyyy-MM-dd HH:mm") } else { '<span class="never">—</span>' }
        $failDisplay     = if ($r.FailedCalls -gt 0) { "<span class='fail-count'>$($r.FailedCalls)</span>" } else { "0" }
        $rowClass        = if ($r.Status -eq "Never Used") { "row-unused" } else { "" }

        $permissionRows += @"
        <tr class="$rowClass">
            <td><strong>$($r.Permission)</strong></td>
            <td>$typeBadge</td>
            <td>$($r.Resource)</td>
            <td class="num">$($r.TotalCalls)</td>
            <td class="num">$failDisplay</td>
            <td>$lastUsedDisplay</td>
            <td>$statusBadge</td>
        </tr>
"@
    }

    $unmappedRows = ""
    if ($unmappedUris -and $unmappedUris.Count -gt 0) {
        foreach ($u in $unmappedUris) {
            $lastUsedDisplay = if ($u.LastUsed) { ([datetime]$u.LastUsed).ToString("yyyy-MM-dd HH:mm") } else { "—" }
            $unmappedRows += @"
            <tr>
                <td><code>$($u.RequestMethod) $($u.NormalizedUri)</code></td>
                <td class="num">$($u.CallCount)</td>
                <td>$lastUsedDisplay</td>
                <td>$($u.PermissionType)</td>
            </tr>
"@
        }
    } else {
        $unmappedRows = '<tr><td colspan="4" style="text-align:center;color:#888;">No unmapped URIs found.</td></tr>'
    }

    $unmappedCount = if ($unmappedUris) { $unmappedUris.Count } else { 0 }

    $recommendationHtml = if ($neverUsedCount -gt 0) {
        $neverUsedList = ($auditResults | Where-Object { $_.Status -eq "Never Used" } | ForEach-Object {
            "          <li><strong>$($_.Permission)</strong> ($($_.Type))</li>"
        }) -join "`n"
        @"
        <div class="recommendation">
            <strong>⚠️ $neverUsedCount permission(s) have never been used</strong> in the last $LookbackDays days.<br><br>
            Consider removing the following permissions after confirming with the application owner:<br><br>
            <ul style="margin-left:20px;margin-top:8px;">$neverUsedList</ul>
        </div>
"@
    } else {
        '<p style="color:#27AE60;font-size:13px;">✅ All registered permissions have been observed in use during the lookback period.</p>'
    }

    $html = @"
