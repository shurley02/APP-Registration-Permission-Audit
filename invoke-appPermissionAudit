# ================================================================
#  Invoke-AppPermissionAudit.ps1
#  Audits Entra ID App Registration API permissions against
#  actual usage in MicrosoftGraphActivityLogs (Log Analytics)
#  and produces color-coded HTML reports.
#
#  MODES:
#    -TargetAppId     Single App ID (original mode)
#    -AppIdList       Comma-separated list of App IDs
#    -InputFile       Path to CSV (AppId column) or TXT (one per line)
#    -DiscoverAll     Auto-discover all admin-managed app registrations
#
#  Requirements:
#    - PowerShell 5.1 or 7+
#    - App Registration with:
#        Application.Read.All  (Microsoft Graph)
#        Data.Read             (Log Analytics API)
#    - Log Analytics Reader RBAC on the workspace
# ================================================================

param (
    # ---- Input Modes (use one) ----
    [string]   $TargetAppId,                    # Single App ID
    [string[]] $AppIdList,                      # Array of App IDs
    [string]   $InputFile,                      # CSV or TXT file path
    [switch]   $DiscoverAll,                    # Auto-discover all admin-managed apps

    # ---- Auditor Credentials ----
    [string]$TenantId        = "<your-tenant-id>",
    [string]$ClientId        = "<your-auditor-app-client-id>",
    [string]$ClientSecret    = "<your-auditor-app-client-secret>",
    [string]$WorkspaceId     = "<your-log-analytics-workspace-id>",

    # ---- Options ----
    [int]   $LookbackDays    = 90,
    [string]$OutputFolder    = $PSScriptRoot,
    [switch]$SkipIndividualReports              # Only generate the summary report
)

